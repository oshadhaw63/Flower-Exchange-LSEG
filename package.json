{
  "name": "flower-exchange-platform",
  "version": "1.0.0",
  "scripts": {
    "start:engine": "cd Flower-Trade && flower_gui.exe",
    "start:bridge": "cd Trader-UI && node bridge.js",
    "start:ui": "cd Trader-UI/frontend && npm run dev",
    "dev": "concurrently -k \"npm run start:engine\" \"npm run start:bridge\" \"npm run start:ui\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "express": "^5.2.1"
  }
}
